{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(gh secret set *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-safety.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/check-branch-pr-status.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -re '.tool_input.file_path') && case \"$FILE\" in \"$HOME\"/.local/share/chezmoi/*) exit 0 ;; esac && SOURCE=$(chezmoi source-path \"$FILE\" 2>/dev/null) && echo \"Blocked: chezmoi managed. Edit: $SOURCE\" >&2 && exit 2 || exit 0"
          },
          {
            "type": "command",
            "command": "FILE=$(jq -re '.tool_input.file_path') && case \"$(basename \"$FILE\")\" in lefthook.yml|lefthook-local.yml|tsconfig.json) echo \"Blocked: $FILE is protected. Fix the code, not the config.\" >&2; exit 2 ;; esac; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -re '.new_string // .content // empty' | grep '^[[:space:]]*\\(//\\|#\\|--\\) *[-=*#/]\\{3,\\}' && { echo 'Warning: Section divider or decorative comments detected. Remove them.' >&2; exit 2; } || exit 0"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/gha-lint.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [],
    "Stop": []
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "autoMemoryEnabled": false,
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyRate": 0,
  "showThinkingSummaries": true
}
