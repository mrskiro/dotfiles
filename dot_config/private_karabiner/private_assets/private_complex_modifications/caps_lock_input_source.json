{
    "title": "CapsLock to toggle input source",
    "rules": [
        {
            "description": "CapsLock to toggle input source (Ctrl+Space)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "caps_lock",
                        "modifiers": { "optional": ["any"] }
                    },
                    "to_if_alone": [
                        {
                            "key_code": "spacebar",
                            "modifiers": ["left_control"]
                        }
                    ]
                }
            ]
        }
    ]
}
